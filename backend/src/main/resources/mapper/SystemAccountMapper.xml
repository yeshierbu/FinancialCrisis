<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erbu.financialcrisis.mapper.SystemAccountMapper">
    <select id="selectByUsername" resultType="com.erbu.financialcrisis.domain.entity.SystemAccount">
        SELECT id, username, password_hash, role_code, display_name, account_status
        FROM system_account WHERE username=#{username} LIMIT 1
    </select>
</mapper>
